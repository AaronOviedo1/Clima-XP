# === Base de datos (Supabase PostgreSQL) ===
# En Supabase: Project Settings → Database → Connection string.
# DATABASE_URL = "Transaction pooler" (puerto 6543) para la app en runtime.
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL = "Session pooler" o conexión directa (puerto 5432) para migraciones de Prisma.
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# === Auth.js (NextAuth v5) ===
# Genera uno con: npx auth secret   (o) node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# === Google Maps (Fase 4) ===
GOOGLE_MAPS_API_KEY=""
BODEGA_LAT=""
BODEGA_LNG=""

# === WhatsApp Business Cloud API (Fase 7) ===
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""
WHATSAPP_VERIFY_TOKEN=""

# === Notificaciones push (Fase 7.5) ===
# Genera el par una sola vez con: npx web-push generate-vapid-keys
# El MISMO par debe ir en Production, Preview y Development: si difieren, las
# suscripciones creadas en un entorno son rechazadas (403) en el otro. Rotarlo
# invalida todas las suscripciones existentes.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:ovy3200@gmail.com"

# === Crons de Vercel (avisos programados) ===
# openssl rand -hex 32 — Vercel lo manda como "Authorization: Bearer …"
CRON_SECRET=""

# === Mercado Pago (Fase 8) ===
MP_ACCESS_TOKEN=""
MP_WEBHOOK_SECRET=""

# === Seed (usuarios iniciales) ===
ADMIN_EMAIL="admin@climaxpress.mx"
ADMIN_PASSWORD="cambia-esto"
REPARTIDOR_EMAIL="repartidor@climaxpress.mx"
REPARTIDOR_PASSWORD="cambia-esto"
