// Schema base — Fase 0 (solo lo necesario para Auth.js con roles).
// El schema completo del dominio (Cliente, Renta, Unidad, etc.) se agrega en la Fase 1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Supabase: pooler en modo transacción (puerto 6543) para la app.
  url       = env("DATABASE_URL")
  // Conexión directa (puerto 5432) para migraciones de Prisma.
  directUrl = env("DIRECT_URL")
}

enum Rol {
  ADMIN
  REPARTIDOR
}

model User {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  rol          Rol      @default(REPARTIDOR)
  createdAt    DateTime @default(now())
}
